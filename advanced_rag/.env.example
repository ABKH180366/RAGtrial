SEARCH_SERVICE_ENDPOINT=https://<your-search-service>.search.windows.net
SEARCH_SERVICE_API_KEY=<search-api-key-or-empty-for-managed-identity>
SEARCH_SERVICE_INDEX_NAME=docs
AOAI_ENDPOINT=https://<your-aoai-resource>.openai.azure.com/
AOAI_API_VERSION=2024-10-21
AOAI_API_KEY=<azure-openai-api-key>
AOAI_EMBEDDING_MODEL_NAME=text-embedding-3-large
AOAI_CHAT_MODEL_NAME=gpt-4o-mini
RAG_DEFAULT_TOP_K=5
RAG_CANDIDATE_POOL_SIZE=20
RAG_MIN_RELEVANCE=0.12
RAG_LOG_PATH=logs/rag_events.jsonl
